{
  "manifest_version": 3,
  "name": "Mojify",
  "version": "1.0",
  "description": "Replaces trigger words with 7TV emotes.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "tabs",
    "clipboardWrite",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://7tv.io/*",
    "https://api.giphy.com/*",
    "https://*.giphy.com/*",
    "https://api.klipy.com/*",
    "https://*.klipy.com/*",
    "https://pixabay.com/*",
    "https://*.pixabay.com/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*",
    "https://*.messenger.com/*",
    "https://*.discord.com/*",
    "https://*.discordapp.com/*",
    "https://*.facebook.com/*",
    "https://*.telegram.org/*",
    "https://*.whatsapp.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
